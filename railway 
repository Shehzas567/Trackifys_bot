function calcRSI(prices, period = 14) {
  if (prices.length < period + 1) return 50;
  let gains = 0, losses = 0;
  for (let i = prices.length - period; i < prices.length; i++) {
    const d = prices[i] - prices[i - 1];
    if (d > 0) gains += d; else losses -= d;
  }
  const ag = gains / period, al = losses / period;
  if (al === 0) return 100;
  return 100 - 100 / (1 + ag / al);
}

function calcMACD(prices) {
  if (prices.length < 26) return { hist: 0 };
  const ema = (arr, span) => {
    const k = 2 / (span + 1);
    let e = arr[0];
    for (let i = 1; i < arr.length; i++) e = arr[i] * k + e * (1 - k);
    return e;
  };
  const fast = ema(prices, 12), slow = ema(prices, 26);
  const line = fast - slow;
  return { hist: line * 0.3 };
}

function calcSR(prices) {
  const resistance = Math.max(...prices.slice(-20)) * 0.99;
  const support    = Math.min(...prices.slice(-20)) * 1.01;
  return { support, resistance };
}

function calcMA(prices, p) {
  const sl = prices.slice(-p);
  return sl.reduce((a, b) => a + b, 0) / sl.length;
}

function analyze(prices) {
  if (!prices || prices.length < 30) return { signal: "WAIT", score: 0, rsi: 50, signals: {} };
  const curr = prices[prices.length - 1];
  const rsi  = calcRSI(prices);
  const macd = calcMACD(prices);
  const { support, resistance } = calcSR(prices);
  const ma20  = calcMA(prices, Math.min(20, prices.length));
  const ma50  = calcMA(prices, Math.min(50, prices.length));
  const ma200 = calcMA(prices, Math.min(200, prices.length));

  const rsiSig  = rsi < 35 ? 1 : rsi > 65 ? -1 : 0;
  const macdSig = macd.hist > 0 ? 1 : macd.hist < 0 ? -1 : 0;
  const srRange = resistance - support;
  const srSig   = srRange > 0 ? (curr < support + srRange * 0.15 ? 1 : curr > resistance - srRange * 0.15 ? -1 : 0) : 0;
  const prev    = prices[prices.length - 2];
  const patSig  = curr > prev * 1.003 ? 1 : curr < prev * 0.997 ? -1 : 0;
  const maSig   = (curr > ma20 && ma20 > ma50) ? 1 : (curr < ma20 && ma20 < ma50) ? -1 : 0;
  const trend   = curr > ma200 ? 1 : -1;

  let buy  = [rsiSig, macdSig, srSig, patSig, maSig].filter(s => s === 1).length;
  let sell = [rsiSig, macdSig, srSig, patSig, maSig].filter(s => s === -1).length;
  if (trend === 1) buy  = Math.min(5, buy + 1);
  if (trend === -1) sell = Math.min(5, sell + 1);

  const signal = buy >= 3 ? "BUY" : sell >= 3 ? "SELL" : "WAIT";
  const score  = signal === "BUY" ? buy : signal === "SELL" ? sell : Math.max(buy, sell);

  return {
    signal, score: Math.min(5, Math.round(score)),
    rsi: rsi.toFixed(1),
    support: support.toFixed(4),
    resistance: resistance.toFixed(4),
    ma20: ma20.toFixed(4),
    ma50: ma50.toFixed(4),
    signals: { RSI: rsiSig, MACD: macdSig, "S/R": srSig, Pattern: patSig, MA: maSig },
  };
}

function MiniChart({ prices, signal }) {
  if (!prices || prices.length < 2) return null;
  const w = 200, h = 36;
  const min = Math.min(...prices), max = Math.max(...prices);
  const range = max - min || 1;
  const pts = prices.map((p, i) => {
    const x = (i / (prices.length - 1)) * w;
    const y = h - ((p - min) / range) * (h - 4) - 2;
    return `${x},${y}`;
  }).join(" ");
  const color = signal === "BUY" ? "#10b981" : signal === "SELL" ? "#ef4444" : "#4a6080";
  return (
    <svg width="100%" height={h} viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="none">
      <polyline points={pts} fill="none" stroke={color} strokeWidth="1.5" strokeLinecap="round" />
    </svg>
  );
}

async function sendTelegramMsg(token, chatId, text) {
  const url = `https://api.telegram.org/bot${token}/sendMessage`;
  const res = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ chat_id: chatId, text, parse_mode: "Markdown" }),
  });
  return res.json();
}

