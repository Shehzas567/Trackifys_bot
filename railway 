                    {Object.entries(sel.signals||{}).map(([k,v]) => (
                      <div key={k} style={{ display:"flex", justifyContent:"space-between", padding:"5px 0", borderBottom:"1px solid #1a2540", fontSize:11 }}>
                        <span style={{ color:"#4a6080", fontFamily:"monospace" }}>{k}</span>
                        <span style={{ color:indColor(v), fontFamily:"monospace" }}>{indLabel(v)}</span>
                      </div>
                    ))}
                  </div>
                )
            )}
          </div>
        </div>
      </div>

      {/* TOAST */}
      {toast && (
        <div style={{ position:"fixed", bottom:20, right:20, background:"#0d1220", border:"1px solid #10b981", borderRadius:8, padding:"10px 16px", fontSize:12, color:"#10b981", fontFamily:"monospace", zIndex:999 }}>
          {toast}
        </div>
      )}
    </div>
  );
}